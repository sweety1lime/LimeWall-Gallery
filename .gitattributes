# Keep wallpaper binaries byte-for-byte so their SHA-256 stays stable
# (the gallery client verifies downloads against the catalog checksum).
*.wpk binary
*.webm binary
*.mp4 binary
*.mkv binary
*.gif binary
*.jpg binary
*.jpeg binary
*.png binary
*.webp binary
*.glb binary

# Generated/tooling text stays LF so the CI catalog drift-check is stable.
gallery/catalog.json text eol=lf
gallery/*.mjs text eol=lf
# Signing inputs must be byte-stable: the client verifies the catalog bytes, and
# the public key is compiled in / read by CI.
gallery/pubkey.ed25519 text eol=lf
gallery/catalog.json.sig text eol=lf
